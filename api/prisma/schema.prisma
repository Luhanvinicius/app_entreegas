// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Using PostgreSQL as requested
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // For Couriers
  isApproved Boolean @default(false) 
  balance    Float   @default(0)

  // For Shopkeepers
  storeId    String?
  store      Store?   @relation(fields: [storeId], references: [id])

  orders      Order[] @relation("CustomerOrders")
  deliveries  Order[] @relation("CourierDeliveries")
  withdrawals Withdrawal[]
}

enum Role {
  ADMIN
  CUSTOMER
  COURIER
  SHOPKEEPER
}

model Store {
  id          String    @id @default(uuid())
  name        String
  description String
  phone       String
  address     String?
  isActive    Boolean   @default(true)
  products    Product[]
  orders      Order[]
  users       User[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  isAvailable Boolean  @default(true)
  orderItems  OrderItem[]
}

enum OrderStatus {
  PENDING
  AVAILABLE
  ACCEPTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  ADVANCE
  ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
}

model Order {
  id            String        @id @default(uuid())
  totalAmount   Float
  deliveryFee   Float
  distance      Float?        // Distância em KM
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(ADVANCE)
  paymentStatus PaymentStatus @default(PENDING)
  
  // Campos Integração Asaas
  asaasId       String?       // ID da fatura no Asaas
  pixCode       String?       // Código Copia e Cola
  pixQrCode     String?       @db.Text // Base64 do QR Code

  address       String
  customerName  String
  customerPhone String
  
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  
  customerId    String?
  customer      User?       @relation("CustomerOrders", fields: [customerId], references: [id])
  courierId     String?
  courier       User?       @relation("CourierDeliveries", fields: [courierId], references: [id])
  
  items         OrderItem[]
  
  arrivedAt     DateTime?   // Horário que o entregador clicou em "Cheguei"
  createdAt     DateTime    @default(now())
}

model Withdrawal {
  id        String   @id @default(uuid())
  amount    Float
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  courierId String
  courier   User     @relation(fields: [courierId], references: [id])
  createdAt DateTime @default(now())
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
